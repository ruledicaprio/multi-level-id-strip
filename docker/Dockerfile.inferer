# Persistent Tier-2 LLM inferer (gRPC, llama.cpp + Qwen GGUF).
#
# GPU build (CUDA 12.4). For CPU-only, swap the base image for
# `python:3.12-slim` and drop the CUDA extra-index wheel line below.
FROM nvidia/cuda:12.4.1-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update \
 && apt-get install -y --no-install-recommends python3 python3-pip \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY python/ /app/python/
COPY proto/ /app/proto/

RUN pip3 install --no-cache-dir --break-system-packages \
      "grpcio>=1.60" "grpcio-tools>=1.60" "pydantic>=2.5" "protobuf>=4.25" \
 && pip3 install --no-cache-dir --break-system-packages \
      llama-cpp-python --extra-index-url https://abetlen.github.io/llama-cpp-python/whl/cu124

# Generate the gRPC stubs from the shared proto contract.
RUN cd /app/python && python3 generate_grpc.py

# The ~1 GB GGUF model is mounted at runtime, never baked into the image.
ENV MODEL_PATH=/models/qwen2.5-1.5b-instruct-q4_k_m.gguf
ENV MLIS_INFERER_BIND=0.0.0.0:50051
EXPOSE 50051

WORKDIR /app/python
CMD ["python3", "-m", "inferer"]
